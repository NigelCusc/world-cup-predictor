# Copy to .env and adjust locally. All variables are optional.

# Paths
# WCP_DATA_DIR=Data
# WCP_MODELS_DIR=models
# WCP_KAGGLE_DATA_DIR=Data/kaggle_fifa_world_cup_team_dataset
# WCP_GROUP_STANDINGS_PATH=Data/group_standings_2026.pkl

# Feature flags (true/false, 1/0, yes/no, on/off)
# WCP_USE_KAGGLE_FEATURES=true
# WCP_SKIP_KAGGLE_DOWNLOAD=false
# WCP_VERBOSE=false
# ITS_COMING_HOME=false  # England losses become draws; knockout draws → penalties

# Scraping
# WCP_USER_AGENT=FifaWorldCupAnalysis/1.0 (educational data project)
# WCP_REQUEST_DELAY_SECONDS=0.15
